# Application
NODE_ENV=development
PORT=3000

# Database (use 'db' for Docker, 'localhost' for local dev)
DB_HOST=db
DB_PORT=5432
DB_USERNAME=swiftship
DB_PASSWORD=swiftship_secret
DB_DATABASE=swiftship

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h

# Redis
# Redis hostname (use 'redis' for Docker Compose, 'localhost' for local development)
REDIS_HOST=redis
# Redis port (default: 6379)
REDIS_PORT=6379
# Redis password (leave empty for unsecured local development)
REDIS_PASSWORD=
# Redis logical database index (0-15, default: 0)
REDIS_DB=0
# Order expiration delay in milliseconds (10 minutes = 600000ms)
ORDER_EXPIRY_MS=600000
